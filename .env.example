# Backend the MCP server delegates business logic to
SMARTSHIFT_API_URL=https://your-backend.example.com
# Shared secret sent as x-mcp-secret header (must match backend)
MCP_SHARED_SECRET=change-me
# Optional: expose kakao-login tools (requires backend KAKAO_REST_API_KEY)
# ENABLE_KAKAO_LOGIN=1
PORT=3000
